# Copia este archivo a .env y completa los valores
# NUNCA commites .env al repositorio

# ─── IA / Modelos ────────────────────────────────────────────────────────────
# Prioridad: GOOGLE_API_KEY > ANTHROPIC_API_KEY > OPENROUTER_API_KEY
# Obtén tu key en: https://aistudio.google.com
# La misma key sirve para Gemini (transcripción + análisis) y YouTube Data API (investigación)
# Para investigación de mercado: activa "YouTube Data API v3" en Google Cloud Console
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Clave para YouTube Data API v3 e YouTube Analytics API
# Créala en: Google Cloud Console → APIs & Services → Credentials → API Key
# Si no la defines, se usa GOOGLE_API_KEY (puede no funcionar con claves de AI Studio)
YOUTUBE_API_KEY=

# Alternativas (opcionales)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Modelo Whisper para transcripción: tiny | base | small | medium | large-v3
WHISPER_MODEL=base

# ─── Pipeline ────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
TMP_DIR=tmp
MAX_CLIPS=5
CLIP_MAX_SECONDS=60

# ─── Publicación: Instagram ───────────────────────────────────────────────────
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ─── Publicación: TikTok (cookies) ───────────────────────────────────────────
# Exporta las cookies de TikTok con la extensión "EditThisCookie" → guardar en este archivo
TIKTOK_COOKIES_FILE=cookies/tiktok.json

# ─── Publicación: YouTube ────────────────────────────────────────────────────
# Local: ruta al archivo generado por scripts/setup_youtube.py
YOUTUBE_CREDENTIALS_FILE=credentials/youtube_oauth.json

# Producción (Railway): pega aquí el contenido completo de credentials/youtube_oauth.json
# Ejemplo: YOUTUBE_TOKEN_JSON={"token":"ya29...","refresh_token":"1//...","client_id":"...","client_secret":"..."}
YOUTUBE_TOKEN_JSON=
