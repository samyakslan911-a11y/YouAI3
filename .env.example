# Copia este archivo a .env y completa los valores
# NUNCA commites .env al repositorio

# ── Gemini AI (obligatorio) ───────────────────────────────────────────────────
GOOGLE_API_KEY=           # Google AI Studio: aistudio.google.com
GEMINI_MODEL=gemini-2.5-flash

# Clave separada para YouTube Data API v3 (opcional — si no se define, se usa GOOGLE_API_KEY)
# Créala en: Google Cloud Console → APIs & Services → Credentials → API Key
YOUTUBE_API_KEY=

# Alternativas de modelo (opcionales)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Imágenes (obligatorio para slides) ───────────────────────────────────────
PEXELS_API_KEY=           # pexels.com/api — activa la cuenta, tarda ~24h

# ── Almacenamiento R2 (opcional, para URLs públicas de clips) ─────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── Publicación: Instagram ────────────────────────────────────────────────────
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ── Publicación: TikTok ───────────────────────────────────────────────────────
TIKTOK_COOKIES_FILE=cookies/tiktok.json   # exportar con EditThisCookie en formato JSON

# ── Publicación: YouTube ──────────────────────────────────────────────────────
YOUTUBE_OAUTH_TOKEN_JSON=                  # JSON completo del oauth token (para Railway)
YOUTUBE_CREDENTIALS=credentials/youtube_oauth.json  # para desarrollo local

# Anti-bot: cookies de youtube.com exportadas con "Get cookies.txt LOCALLY" (Chrome/Firefox)
# Railway: agrega como variable YOUTUBE_COOKIES con el contenido completo del archivo
YOUTUBE_COOKIES=

# ── Transcripción (opcional, default=base) ────────────────────────────────────
WHISPER_MODEL=base        # base|small|medium|large-v2|large-v3

# ── Slides ────────────────────────────────────────────────────────────────────
CHANNEL_HANDLE=@tucanal   # aparece en el footer de cada slide

# ── Pipeline ──────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
TMP_DIR=tmp
MAX_CLIPS=5
CLIP_MAX_SECONDS=60
